PORT=3000
JSON_BODY_LIMIT=15mb
DATABASE_URL=postgres://certificates_user:certificates_password@localhost:5432/certificates_db
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_ADMIN_TOKEN=

# WOWlife partner authorization
AUTH_BASE_URL=https://partner-wowlife.ru
AUTH_PASSWORD_URL=https://partner-wowlife.ru/restapi/auth.goPassword
AUTH_GET_CODE_URL=https://partner-wowlife.ru/restapi/auth.getCode
AUTH_CODE_URL=https://partner-wowlife.ru/restapi/auth.getCode
AUTH_AUTHENTICATION_URL=https://partner-wowlife.ru/restapi/auth.authentication
AUTH_AUTHORIZATION_URL=https://partner-wowlife.ru/restapi/auth.authorization
AUTH_SET_PASSWORD_URL=https://partner-wowlife.ru/restapi/auth.setPassword
AUTH_DOMAIN=wowlife-crm.ru
AUTH_CABINET=partner
AUTH_METHOD=password
AUTH_PHONE_METHOD=phone
AUTH_EMAIL_METHOD=email
# Optional: use these only if WOWlife returns contactId/token in a non-standard nested shape.
# Examples: data.contact.id, result.contact.ID, data.token
AUTH_PASSWORD_CONTACT_ID_PATH=
AUTH_PASSWORD_TOKEN_PATH=
AUTH_SESSION_SECRET=replace-with-long-random-string
AUTH_SESSION_TTL_SECONDS=604800
# Set to true only for local UI development without remote auth.
AUTH_DISABLED=false

# Certificate list source: true = WOWlife service, false = local PostgreSQL database.
CERTIFICATES_USE_SERVICE=true
CERTIFICATES_SERVICE_URL=https://partner-wowlife.ru/restapi/certificate.getPartnerCertificates
CERTIFICATE_REDEEM_INFO_URL=https://partner-wowlife.ru/restapi/certificate.getCertificateForRedeem
CERTIFICATE_REDEEM_URL=https://partner-wowlife.ru/restapi/certificate.redeemCertificate
CERTIFICATE_LAST_VERIFICATION_DATE_URL=https://partner-wowlife.ru/restapi/certificate.getLastVerificationDate
CERTIFICATE_CREATE_VERIFICATION_URL=https://partner-wowlife.ru/restapi/certificate.createVerification
CERTIFICATES_GROUP_IDS=new,waiting,confirmed,visited,verification,paid,canceled
# Payment requests source when CERTIFICATES_USE_SERVICE=true
VERIFICATIONS_SERVICE_URL=https://partner-wowlife.ru/restapi/certificate.getVerifications

# Partner profile source
PROFILE_SERVICE_URL=https://partner-wowlife.ru/restapi/profile.getProfile
PROFILE_NOTIFICATION_CHANNELS_URL=https://partner-wowlife.ru/restapi/profile.getNotificationChannels
PROFILE_SET_NOTIFICATION_CHANNELS_URL=https://partner-wowlife.ru/restapi/profile.setNotificationChannels
PROFILE_SET_PARTNER_PROFILE_URL=https://partner-wowlife.ru/restapi/profile.setPartnerProfile
PROFILE_SET_AGENT_REPORT_URL=https://partner-wowlife.ru/restapi/profile.setAgentReport
# Optional fallback cabinet for profile.getProfile. Usually leave empty: the app first tries AUTH_CABINET.
PROFILE_CABINET=
# Cache profile responses to avoid repeated address requests while the user is working.
PROFILE_CACHE_TTL_MS=300000
# The documented WOWlife profile payload does not require domain. Enable only if WOWlife asks for it.
PROFILE_INCLUDE_DOMAIN=false

# Certificate stage change / appointment dialog
CERTIFICATE_STAGE_CHANGE_URL=https://partner-wowlife.ru/restapi/certificate.changeCertificateStage
CERTIFICATE_SCHEDULE_STAGE_ID=C2:UC_4Q05NY
CERTIFICATE_ACCEPT_WORK_STAGE_ID=C2:NEW
CERTIFICATE_NEW_STAGE_ID=C2:UC_MCMFWK
CERTIFICATE_SCHEDULE_TIME_ZONE=Europe/Moscow

# Partner products / services page
# allIds for product.getPartnerProducts are derived from partner profile, not hardcoded in env.
PRODUCTS_SERVICE_URL=https://partner-wowlife.ru/restapi/product.getPartnerProducts
PRODUCT_CHANGE_PARTNER_PRODUCT_URL=https://partner-wowlife.ru/restapi/product.changePartnerProduct
PRODUCT_ADD_PARTNER_PRODUCT_URL=https://partner-wowlife.ru/restapi/product.addPartnerProduct

# YCLIENTS Booking external opening/API authorization
# Before opening YCLIENTS in a new tab, the backend authorizes via API using Partner token + user credentials.
YCLIENTS_API_BASE_URL=https://api.yclients.com/api/v1
YCLIENTS_AUTH_URL=https://api.yclients.com/api/v1/auth
YCLIENTS_COMPANIES_URL=https://api.yclients.com/api/v1/companies
YCLIENTS_WEB_LOGIN_URL=https://www.yclients.com/auth/login/1
YCLIENTS_TIMETABLE_BASE_URL=https://yclients.com
YCLIENTS_PARTNER_TOKEN=
# Optional: system user token from YCLIENTS Marketplace -> Access to API.
YCLIENTS_USER_TOKEN=
# Login/password for YCLIENTS are taken from the saved fields on /crm-data, not from env.

# Local PUSH admin access
# Used by migrations/005_create_admin_push.sql to seed the first super admin.
ADMIN_SUPER_LOGIN=superadmin
ADMIN_SUPER_PASSWORD=change-me-strong-password
ADMIN_SESSION_SECRET=replace-with-admin-session-secret
ADMIN_SESSION_TTL_SECONDS=43200
# Invite code for /admin/register. The user-visible code is called my-invite.
MY_INVITE_CODE=replace-with-my-invite-code

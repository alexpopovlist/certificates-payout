PORT=3000
DATABASE_URL=postgres://certificates_user:certificates_password@localhost:5432/certificates_db
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com
PUSH_ADMIN_TOKEN=

# WOWlife partner authorization
AUTH_BASE_URL=https://partner-wowlife.ru
# Set this to the exact service endpoint if WOWlife changes it or if the fallback paths do not match.
# AUTH_LOGIN_URL=https://partner-wowlife.ru/api/authentication/sign-in
# Optional path used with AUTH_BASE_URL when AUTH_LOGIN_URL is not set.
# AUTH_LOGIN_PATH=/api/authentication/sign-in
AUTH_USERNAME_FIELD=login
AUTH_PASSWORD_FIELD=password
AUTH_SESSION_SECRET=replace-with-long-random-string
AUTH_SESSION_TTL_SECONDS=604800
# Set to true only for local UI development without remote auth.
AUTH_DISABLED=false
